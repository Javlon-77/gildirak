<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Omad G'ildiragi Shou 🎡</title>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <style>
        :root {
            --bg-color: #090d16;
            --card-bg: #111827;
            --accent-color: #f59e0b;
            --text-color: #f3f4f6;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Poppins', 'Segoe UI', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        /* --- FOYDALANUVChI REJIMIDAGI DIZAYN --- */
        #userView {
            display: none; /* Skript orqali boshqariladi */
            width: 100%;
            max-width: 400px;
        }

        .register-card {
            background-color: var(--card-bg);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5), 0 0 20px rgba(16, 185, 129, 0.2);
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .register-card h1 {
            font-size: 1.8rem;
            margin-bottom: 10px;
            background: linear-gradient(45deg, #10b981, #3b82f6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .register-card p {
            color: #9ca3af;
            font-size: 0.9rem;
            margin-bottom: 25px;
        }

        input {
            width: 100%;
            background-color: #090d16;
            border: 2px solid #374151;
            border-radius: 12px;
            padding: 14px;
            color: white;
            font-size: 1rem;
            outline: none;
            box-sizing: border-box;
            transition: border-color 0.3s;
            margin-bottom: 20px;
            text-align: center;
        }

        input:focus {
            border-color: #10b981;
        }

        .reg-btn {
            width: 100%;
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
            border: none;
            padding: 14px;
            font-size: 1.1rem;
            font-weight: bold;
            border-radius: 12px;
            cursor: pointer;
            transition: transform 0.1s, opacity 0.2s;
        }

        .reg-btn:active {
            transform: scale(0.98);
        }

        .status {
            margin-top: 15px;
            font-size: 0.95rem;
            font-weight: 500;
            min-height: 22px;
        }

        /* --- ADMIN REJIMIDAGI DIZAYN --- */
        #adminView {
            display: none; /* Skript orqali boshqariladi */
            width: 100%;
            max-width: 1050px;
        }

        .main-container {
            display: flex;
            flex-direction: row;
            gap: 40px;
            background-color: var(--card-bg);
            padding: 30px;
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.7), 0 0 40px rgba(245, 158, 11, 0.1);
            align-items: center;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        @media (max-width: 950px) {
            .main-container { flex-direction: column; text-align: center; }
        }

        .wheel-section {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            flex: 1.1;
        }

        .pointer {
            position: absolute;
            top: -20px;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 0;
            border-left: 18px solid transparent;
            border-right: 18px solid transparent;
            border-top: 35px solid #ef4444;
            z-index: 10;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.5));
        }

        canvas {
            border-radius: 50%;
            box-shadow: 0 0 30px rgba(245, 158, 11, 0.3), 0 0 0 10px #1f2937;
            transition: transform 4s cubic-bezier(0.1, 0.8, 0.1, 1);
        }

        .center-circle {
            position: absolute;
            width: 60px;
            height: 60px;
            background: radial-gradient(circle, #ffffff 0%, #d1d5db 100%);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            font-weight: bold;
            color: #090d16;
            font-size: 0.9rem;
            user-select: none;
            z-index: 5;
            border: 3px solid #1f2937;
        }

        .control-section {
            flex: 1.2;
            display: flex;
            flex-direction: column;
            gap: 20px;
            width: 100%;
        }

        h1 {
            font-size: 2rem;
            background: linear-gradient(45deg, #f59e0b, #ef4444, #3b82f6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
        }

        .active-count {
            font-size: 1.1rem;
            color: #10b981;
            font-weight: 600;
        }

        .spin-btn {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: #090d16;
            border: none;
            padding: 14px;
            font-size: 1.1rem;
            font-weight: 800;
            border-radius: 14px;
            cursor: pointer;
            text-transform: uppercase;
            transition: all 0.3s;
            box-shadow: 0 5px 15px rgba(245, 158, 11, 0.3);
        }

        .spin-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(245, 158, 11, 0.5);
        }

        .spin-btn:disabled {
            background: #374151;
            color: #6b7280;
            cursor: not-allowed;
            box-shadow: none;
        }

        .reset-btn {
            background-color: #374151;
            color: #f3f4f6;
            border: none;
            padding: 8px 15px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.85rem;
            transition: background 0.2s;
        }

        .reset-btn:hover { background-color: #ef4444; }

        .podium-container {
            display: flex;
            justify-content: space-around;
            align-items: flex-end;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 15px 10px;
            min-height: 150px;
        }

        .podium-place { display: flex; flex-direction: column; align-items: center; width: 30%; }
        .podium-name { font-size: 0.85rem; font-weight: bold; text-align: center; margin-bottom: 8px; min-height: 20px; color: #9ca3af; word-break: break-all; }
        .podium-block { width: 100%; display: flex; justify-content: center; align-items: center; font-size: 1.3rem; font-weight: bold; border-radius: 8px 8px 0 0; color: #090d16; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }

        .place-2 .podium-block { height: 45px; background: linear-gradient(to top, #94a3b8, #cbd5e1); }
        .place-1 .podium-block { height: 75px; background: linear-gradient(to top, #d97706, #fcd34d); }
        .place-3 .podium-block { height: 30px; background: linear-gradient(to top, #b45309, #f97316); }

        .current-status { text-align: center; font-weight: bold; color: #60a5fa; font-size: 1.1rem; min-height: 27px; }
    </style>
</head>
<body>

<!-- ============================================== -->
<!-- 1. FOYDALANUVCHILAR REJIMI (ISYON / RO'YXAT)   -->
<!-- ============================================== -->
<div id="userView">
    <div class="register-card">
        <h1>Omad G'ildiragi</h1>
        <p>Ismingizni kiriting va o'yinga qo'shiling!</p>
        
        <input type="text" id="userName" placeholder="Ismingizni yozing..." required>
        <button class="reg-btn" onclick="registerName()">Ro'yxatdan o'tish 🚀</button>
        
        <div class="status" id="statusMessage"></div>
    </div>
</div>

<!-- ============================================== -->
<!-- 2. ADMIN REJIMI (G'ILDIRAK VA SHOHSUPA)        -->
<!-- ============================================== -->
<div id="adminView">
    <div class="main-container">
        <div class="wheel-section">
            <div class="pointer"></div>
            <canvas id="wheelCanvas" width="400" height="400"></canvas>
            <div class="center-circle" onclick="startTournament()">GO!</div>
        </div>

        <div class="control-section">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h1>Omad Shou G'ildiragi</h1>
                    <div class="active-count" id="countDisplay">Ishtirokchilar: 0 ta</div>
                </div>
                <button class="reset-btn" onclick="clearDatabase()">Ro'yxatni Tozalash</button>
            </div>

            <button class="spin-btn" id="spinBtn" onclick="startTournament()">Start! 🏆</button>
            <div class="current-status" id="statusBox">Ishtirokchilar ro'yxatdan o'tishini kutyapmiz...</div>

            <div class="podium-container">
                <div class="podium-place place-2">
                    <div class="podium-name" id="name-2">-</div>
                    <div class="podium-block">2</div>
                </div>
                <div class="podium-place place-1">
                    <div class="podium-name" id="name-1">-</div>
                    <div class="podium-block">1</div>
                </div>
                <div class="podium-place place-3">
                    <div class="podium-name" id="name-3">-</div>
                    <div class="podium-block">3</div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Firebase Realtime Database manzilingizni shu yerga qo'ying (oxirida / qolsin)
    const DATABASE_URL = "https://console.firebase.google.com/project/gildirak-63c96/database/gildirak-63c96-default-rtdb/data/~2F?fb_gclid=Cj0KCQjwguLSBhDLARIsAH-yPrFOBqkVMEn5pDBzx8Y111pOIZmWeVSr49mxfBY9t-wcHMXuxfuRIxYaAreEEALw_wcB&fb_utm_campaign=Cloud-SS-DR-Firebase-FY26-global-gsem-1713590&fb_utm_content=text-ad&fb_utm_medium=cpc&fb_utm_source=google&fb_utm_term=KW_https%20console%20firebase%20google%20com";

    // ----------------------------------------------------
    // REJIMLARNI ANIQLASH SCRIPT-i (URL orqali boshqarish)
    // ----------------------------------------------------
    const urlParams = new URLSearchParams(window.location.search);
    const mode = urlParams.get('mode');

    if (mode === 'admin') {
        document.getElementById('adminView').style.display = 'block';
        initAdminLogic();
    } else {
        document.getElementById('userView').style.display = 'block';
    }

    // ----------------------------------------------------
    // FOYDALANUVCHILAR LOGIKASI (Ism qo'shish)
    // ----------------------------------------------------
    async function registerName() {
        const nameInput = document.getElementById('userName');
        const statusDiv = document.getElementById('statusMessage');
        const name = nameInput.value.trim();

        if (name === "") {
            alert("Iltimos, ismingizni yozing!");
            return;
        }

        statusDiv.style.color = "#60a5fa";
        statusDiv.innerText = "Yuborilmoqda...";

        try {
            const response = await fetch(`${DATABASE_URL}participants.json`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: name, timestamp: Date.now() })
            });

            if (response.ok) {
                statusDiv.style.color = "#10b981";
                statusDiv.innerText = "Siz muvaffaqiyatli qo'shildingiz! 🎉 Katta ekranga qarang.";
                nameInput.value = "";
            } else {
                throw new Error();
            }
        } catch (error) {
            statusDiv.style.color = "#ef4444";
            statusDiv.innerText = "Xatolik yuz berdi. Qaytadan urinib ko'ring.";
        }
    }

    // ----------------------------------------------------
    // ADMIN LOGIKASI (G'ildirak va boshqaruv)
    // ----------------------------------------------------
    function initAdminLogic() {
        const canvas = document.getElementById('wheelCanvas');
        const ctx = canvas.getContext('2d');
        const spinBtn = document.getElementById('spinBtn');
        const statusBox = document.getElementById('statusBox');
        const countDisplay = document.getElementById('countDisplay');

        const colors = ['#f59e0b', '#3b82f6', '#10b981', '#ef4444', '#8b5cf6', '#ec4899', '#06b6d4', '#14b8a6'];

        window.participants = [];
        window.activeParticipants = [];
        window.currentRotation = 0;
        window.isSpinning = false;
        window.audioCtx = null;
        window.currentPlaceToDraw = 3;

        // Real-vaqtda Firebase'dan yuklab olish
        window.fetchParticipants = async function() {
            if (window.isSpinning) return; 

            try {
                const response = await fetch(`${DATABASE_URL}participants.json`);
                const data = await response.json();
                
                if (data && typeof data === 'object') {
                    window.participants = Object.values(data).map(item => item.name);
                } else {
                    window.participants = [];
                }
                
                countDisplay.innerText = `Ishtirokchilar: ${window.participants.length} ta`;
                drawWheel();
            } catch (error) {
                console.error("Xatolik yuz berdi:", error);
            }
        };

        window.clearDatabase = async function() {
            if (window.isSpinning) return;
            if (!confirm("Haqiqatan ham barcha ishtirokchilarni o'chirib tashlamoqchimisiz?")) return;

            try {
                await fetch(`${DATABASE_URL}participants.json`, { method: 'DELETE' });
                window.participants = [];
                document.getElementById('name-1').innerText = '-';
                document.getElementById('name-2').innerText = '-';
                document.getElementById('name-3').innerText = '-';
                statusBox.innerText = "Ro'yxat tozalandi. Yangi ismlarni kutamiz!";
                window.fetchParticipants();
            } catch (error) {
                alert("Tozalashda xatolik yuz berdi");
            }
        };

        function initAudio() {
            if (!window.audioCtx) {
                window.audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
        }

        function playTickSound() {
            initAudio();
            if (!window.audioCtx) return;
            const osc = window.audioCtx.createOscillator();
            const gain = window.audioCtx.createGain();
            osc.type = 'triangle';
            osc.frequency.setValueAtTime(1000, window.audioCtx.currentTime);
            osc.frequency.exponentialRampToValueAtTime(100, window.audioCtx.currentTime + 0.06);
            gain.gain.setValueAtTime(0.1, window.audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, window.audioCtx.currentTime + 0.06);
            osc.connect(gain);
            gain.connect(window.audioCtx.destination);
            osc.start();
            osc.stop(window.audioCtx.currentTime + 0.06);
        }

        function playWinSound(place) {
            initAudio();
            if (!window.audioCtx) return;
            const freqs = place === 1 ? [523.25, 659.25, 783.99, 1046.50] : [392.00, 493.88, 587.33, 783.99];
            freqs.forEach((freq, index) => {
                setTimeout(() => {
                    const osc = window.audioCtx.createOscillator();
                    const gain = window.audioCtx.createGain();
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(freq, window.audioCtx.currentTime);
                    gain.gain.setValueAtTime(0.15, window.audioCtx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.01, window.audioCtx.currentTime + 0.4);
                    osc.connect(gain);
                    gain.connect(window.audioCtx.destination);
                    osc.start();
                    osc.stop(window.audioCtx.currentTime + 0.4);
                }, index * 100);
            });
        }

        function drawWheel() {
            const list = window.isSpinning ? window.activeParticipants : window.participants;
            const numSegments = list.length;
            const radius = canvas.width / 2;
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            if (numSegments === 0) {
                ctx.fillStyle = '#6b7280';
                ctx.font = '16px sans-serif';
                ctx.textAlign = 'center';
                ctx.fillText("Ishtirokchilar kutilmoqda...", radius, radius);
                return;
            }

            const arcSize = (2 * Math.PI) / numSegments;

            for (let i = 0; i < numSegments; i++) {
                const angle = i * arcSize;
                ctx.fillStyle = colors[i % colors.length];
                ctx.beginPath();
                ctx.moveTo(radius, radius);
                ctx.arc(radius, radius, radius - 5, angle, angle + arcSize);
                ctx.closePath();
                ctx.fill();

                ctx.strokeStyle = 'rgba(255,255,255,0.1)';
                ctx.lineWidth = 2;
                ctx.stroke();

                ctx.save();
                ctx.translate(radius, radius);
                ctx.rotate(angle + arcSize / 2);
                ctx.textAlign = 'right';
                ctx.fillStyle = '#ffffff';
                ctx.font = 'bold 13px sans-serif';
                
                let text = list[i];
                if (text.length > 12) text = text.substring(0, 10) + '...';
                
                ctx.fillText(text, radius - 20, 5);
                ctx.restore();
            }
        }

        window.startTournament = function() {
            if (window.isSpinning) return;

            if (window.participants.length < 3) {
                alert("G'ildirakni aylantirish uchun kamida 3 ta ishtirokchi ro'yxatdan o'tishi kerak!");
                return;
            }

            window.activeParticipants = [...window.participants];
            document.getElementById('name-1').innerText = '-';
            document.getElementById('name-2').innerText = '-';
            document.getElementById('name-3').innerText = '-';
            
            window.currentPlaceToDraw = 3;
            runSingleSpin();
        };

        function runSingleSpin() {
            window.isSpinning = true;
            spinBtn.disabled = true;

            statusBox.innerText = `🌀 ${window.currentPlaceToDraw}-o'rin aniqlanmoqda...`;

            const numSegments = window.activeParticipants.length;
            const arcSize = 360 / numSegments;
            const spinAngle = Math.floor(Math.random() * 360) + 1440;
            const targetRotation = window.currentRotation + spinAngle;
            
            const startTime = performance.now();
            const duration = 4000;
            let lastTickAngle = 0;

            function animate(timestamp) {
                const elapsed = timestamp - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const easeOut = 1 - Math.pow(1 - progress, 3);
                
                const currentAngle = window.currentRotation + (spinAngle * easeOut);
                canvas.style.transform = `rotate(${currentAngle}deg)`;

                const segmentProgress = Math.floor(currentAngle / arcSize);
                if (segmentProgress !== lastTickAngle) {
                    playTickSound();
                    lastTickAngle = segmentProgress;
                }

                if (progress < 1) {
                    requestAnimationFrame(animate);
                } else {
                    window.currentRotation = targetRotation % 360;
                    
                    const normalizedAngle = (360 - (window.currentRotation % 360) + 270) % 360;
                    const winnerIndex = Math.floor(normalizedAngle / arcSize) % numSegments;
                    const winner = window.activeParticipants[winnerIndex];

                    document.getElementById(`name-${window.currentPlaceToDraw}`).innerText = winner;
                    document.getElementById(`name-${window.currentPlaceToDraw}`).style.color = 
                        window.currentPlaceToDraw === 1 ? '#fcd34d' : (window.currentPlaceToDraw === 2 ? '#cbd5e1' : '#f97316');

                    playWinSound(window.currentPlaceToDraw);

                    if (typeof confetti === 'function') {
                        confetti({
                            particleCount: 80,
                            spread: 60,
                            origin: { y: 0.6 }
                        });
                    }

                    window.activeParticipants.splice(winnerIndex, 1);
                    drawWheel();

                    setTimeout(() => {
                        if (window.currentPlaceToDraw > 1) {
                            window.currentPlaceToDraw--;
                            runSingleSpin();
                        } else {
                            statusBox.innerText = "🏆 Musobaqa yakunlandi! Tabriklaymiz! 🏆";
                            
                            if (typeof confetti === 'function') {
                                let end = Date.now() + (2 * 1000);
                                (function frame() {
                                    confetti({ particleCount: 5, angle: 60, spread: 55, origin: { x: 0 } });
                                    confetti({ particleCount: 5, angle: 120, spread: 55, origin: { x: 1 } });
                                    if (Date.now() < end) {
                                        requestAnimationFrame(frame);
                                    }
                                }());
                            }

                            window.isSpinning = false;
                            spinBtn.disabled = false;
                        }
                    }, 2000);
                }
            }

            requestAnimationFrame(animate);
        }

        setInterval(window.fetchParticipants, 2000);
        window.fetchParticipants();
    }
</script>

</body>
</html>
